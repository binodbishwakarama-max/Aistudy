# --- API Keys ---
GROQ_API_KEY=gsk_your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
PORT=3000

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Redis Configuration (For Async Background Jobs) ---
# Use Upstash (Cloud) or run a local Docker Redis instance.
# Example: redis://default:your-password@your-endpoint.upstash.io:32402
# Leaving this blank will disable background workers and fallback to synchronous processing.
REDIS_URL=_here

# --- CORS ---
ALLOWED_ORIGIN=http://localhost:5173

# --- SMTP Configuration (Optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_SENDER_NAME="MindFlow Study App"
